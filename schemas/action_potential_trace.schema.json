{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://neuron7xlab/noesis/schemas/action_potential_trace.schema.json",
  "title": "Action Potential Trace",
  "description": "Ordered gated state transitions: state_t -> gate_score -> decision -> artifact_delta -> state_t+1.",
  "type": "object",
  "additionalProperties": false,
  "required": ["trace_id", "records"],
  "properties": {
    "trace_id": { "type": "string", "minLength": 1 },
    "records": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "trace_id",
          "cycle_id",
          "state_t",
          "intent_delta",
          "unfinished_work_delta",
          "gate_score",
          "threshold",
          "decision",
          "artifact_delta",
          "rollback_condition",
          "state_t_plus_1"
        ],
        "properties": {
          "trace_id": { "type": "string", "minLength": 1 },
          "cycle_id": { "type": "integer", "minimum": 0 },
          "state_t": { "type": "string", "minLength": 1 },
          "intent_delta": { "type": "string", "minLength": 1 },
          "unfinished_work_delta": { "type": "string" },
          "gate_score": { "type": "number" },
          "threshold": { "type": "number" },
          "decision": {
            "type": "string",
            "enum": ["BELOW_THRESHOLD", "PASS", "FAIL", "REROUTE", "HUMAN_REVIEW"]
          },
          "artifact_delta": { "type": "string", "minLength": 1 },
          "rollback_condition": { "type": "string", "minLength": 1 },
          "state_t_plus_1": { "type": "string", "minLength": 1 }
        }
      }
    },
    "metrics": {
      "type": "object",
      "required": [
        "trace_completeness_rate",
        "rollback_defined_rate",
        "decision_explainability_rate"
      ],
      "properties": {
        "trace_completeness_rate": { "type": "number", "minimum": 0, "maximum": 1 },
        "rollback_defined_rate": { "type": "number", "minimum": 0, "maximum": 1 },
        "decision_explainability_rate": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    }
  }
}
