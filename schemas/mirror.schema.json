{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://neuron7xlab.org/cme/mirror.schema.json",
  "title": "MirrorArtifact",
  "type": "object",
  "additionalProperties": false,
  "required": ["surface_intent","hidden_goal","constraint","blocker","next_action","success_metric","time_horizon","critical_risk","risk_reduction","finalizer"],
  "properties": {
    "surface_intent": {"type": "string", "minLength": 1},
    "hidden_goal": {"type": "string", "minLength": 1},
    "constraint": {"type": "string", "minLength": 1},
    "blocker": {"type": "string", "minLength": 1},
    "next_action": {"type": "string", "minLength": 1},
    "success_metric": {"type": "string", "minLength": 1},
    "time_horizon": {"type": "string", "minLength": 1},
    "critical_risk": {"type": "string", "minLength": 1},
    "risk_reduction": {"type": "string", "minLength": 1},
    "finalizer": {"type": "string", "minLength": 1}
  }
}
