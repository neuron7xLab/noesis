{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://neuron7xlab.org/cme/validation.schema.json",
  "title": "ValidationReport",
  "type": "object",
  "additionalProperties": false,
  "required": ["artifact_type","passed","checks"],
  "properties": {
    "artifact_type": {"type": "string"},
    "passed": {"type": "boolean"},
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name","passed","detail"],
        "properties": {
          "name": {"type": "string"},
          "passed": {"type": "boolean"},
          "detail": {"type": "string"}
        }
      }
    }
  }
}
