{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://neuron7xlab.org/cmm/artifact.schema.json",
  "title": "MethodArtifact",
  "description": "Контракт методу: 7 обов'язкових секцій. Без усіх семи — не приймається.",
  "type": "object",
  "additionalProperties": false,
  "required": ["definition", "input", "method", "output", "validation", "example", "failure_modes"],
  "properties": {
    "definition": {"type": "string", "minLength": 1},
    "input": {"type": "string", "minLength": 1},
    "method": {"type": "string", "minLength": 1},
    "output": {"type": "string", "minLength": 1},
    "validation": {"type": "string", "minLength": 1},
    "example": {"type": "string", "minLength": 1},
    "failure_modes": {"type": "string", "minLength": 1}
  }
}
